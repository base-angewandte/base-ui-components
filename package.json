{
  "name": "base-ui-components",
  "version": "4.0.0",
  "private": false,
  "description": "base Angewandte Component Library",
  "author": "baseAngewandte <basemail@uni-ak.ac.at>",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://base.uni-ak.ac.at",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:watch": "vite build && vite build --watch",
    "build:transform-css": "sh build/transform-css.sh",
    "build:post-commands": "npm run build:transform-css",
    "preview": "vite preview",
    "lint": "npm run lint:js",
    "lint:fix": "npm run lint:js -- --fix",
    "lint:js": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "version-publish": "sh ./version-publish.sh",
    "prepublishOnly": "npm run build",
    "styleguide": "concurrently \"vue-docgen -c docgen.config.js --watch\" \"vitepress dev --port 6060 docs\"",
    "styleguide:build": "vue-docgen -c docgen.config.js && vitepress build docs",
    "svg": "node build/generate-svg-sprite-sheet.cjs",
    "prepare": "husky",
    "changelog": "gulp -f gulpfile.js changelog"
  },
  "type": "module",
  "main": "./dist/base-ui-components.umd.cjs",
  "module": "./dist/base-ui-components.js",
  "exports": {
    ".": {
      "import": "./dist/base-ui-components.js",
      "require": "./dist/base-ui-components.umd.cjs"
    },
    "./base-ui-components.css": "./dist/base-ui-components.css"
  },
  "files": [
    "dist/*"
  ],
  "dependencies": {
    "@vueuse/components": "^11.2.0",
    "@vueuse/core": "^11.2.0",
    "body-scroll-lock": "^4.0.0-beta.0",
    "hls.js": "^1.5.15",
    "lazysizes": "^5.3.2",
    "leaflet": "^1.9.3",
    "leaflet-responsive-popup": "^1.0.0",
    "leaflet.markercluster": "^1.5.3",
    "normalize.css": "^8.0.1",
    "swiper": "^11.1.10",
    "vue-datepicker-next": "^1.0.3",
    "vue-draggable-plus": "^0.5.3"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.25.9",
    "@babel/plugin-transform-runtime": "^7.24.7",
    "@babel/preset-env": "^7.25.3",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.14.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "axios": "^1.2.1",
    "clean-css-cli": "^5.6.3",
    "concurrently": "^9.1.0",
    "es-module-lexer": "^1.5.4",
    "eslint": "^9.15.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-vue": "^9.31.0",
    "eslint-plugin-vuejs-accessibility": "^2.4.1",
    "globby": "^14.0.2",
    "gulp": "^5.0.0",
    "gulp-conventional-changelog": "^5.0.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.41",
    "postcss-cli": "^11.0.0",
    "postcss-discard-comments": "^7.0.2",
    "postcss-import": "^16.1.0",
    "postcss-url": "^10.1.3",
    "sass": "^1.77.8",
    "svgo": "^3.2.0",
    "svgstore-cli": "^2.0.1",
    "vite": "^5.3.1",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-vue-devtools": "^7.3.1",
    "vitepress": "^1.2.3",
    "vue-docgen-api": "^4.78.0",
    "vue-docgen-cli": "^4.79.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-live": "^2.5.4"
  },
  "peerDependencies": {
    "vue": "^3.1.5"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ],
  "engines": {
    "node": ">= 18.0.0 <21.0.0",
    "npm": ">= 9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/base-angewandte/base-ui-components.git"
  },
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "lint-staged": {
    "src/**/.{js,vue}": "npm run lint:js"
  },
  "overrides": {
    "@babel/traverse": {
      "globals": "^13.24.0"
    },
    "@babel/preset-env": {
      "globals": "^13.24.0"
    }
  }
}
